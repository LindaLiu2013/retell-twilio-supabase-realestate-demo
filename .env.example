PORT=3000
PUBLIC_BASE_URL=https://your-render-service.onrender.com

# Retell
RETELL_API_KEY=key_xxx
RETELL_AGENT_ID=agent_xxx
RETELL_VERIFY_SIGNATURE=true
RETELL_SIP_URI=sip:sip.retellai.com;transport=tcp

# Supabase REST API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_LEADS_TABLE=leads

# Twilio voice + SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+61400000000
NOTIFY_SMS_TO=+61411111111

# Optional email notification via Resend
RESEND_API_KEY=re_xxx
EMAIL_FROM=AI Receptionist <notifications@yourdomain.com>
NOTIFY_EMAIL_TO=sales@yourdomain.com
