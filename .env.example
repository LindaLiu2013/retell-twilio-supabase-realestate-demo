PORT=3000
PUBLIC_BASE_URL=https://your-render-service.onrender.com

# Admin portal
CONFIG_CACHE_TTL_MS=30000

# Retell
RETELL_API_KEY=key_xxx
RETELL_AGENT_ID=agent_xxx
RETELL_VERIFY_SIGNATURE=true
RETELL_SIP_URI=sip:sip.retellai.com;transport=tcp

# Optional OpenAI enrichment for priority and salesperson handoff summary.
# If omitted, the app falls back to rule-based priority and summary.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Supabase REST API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_LEADS_TABLE=leads

# Optional Twilio SMS notification.
# Leave blank if you do not have a Twilio SMS-capable number yet.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
NOTIFY_SMS_TO=

# Optional email notification via Resend
RESEND_API_KEY=
EMAIL_FROM=
NOTIFY_EMAIL_TO=
